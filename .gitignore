training-output/

# ship-issue per-issue acceptance JSON written by workspace-level
# scripts/ship-issue-pick.py; bot's CC sandbox reads from working tree.
.ship-issue-tmp/

# doctr package (git clone https://github.com/mindee/doctr.git doctr_package)
doctr_package/**

.ruff_cache

# Reorganize-pipeline regression test outputs — regenerated on every pytest
# run from inputs/ + expected_text/baseline/. Only the inputs and baselines
# belong in source control.
tests/fixtures/layout_regression/debug/
tests/fixtures/layout_regression/expected_text/current/
tests/fixtures/layout_regression/expected_text/diff/

# Claude Code session state — agent memory canonical home is
# /workspaces/ocr-container/.claude/agent-memory/, not per-repo. If you
# see a .claude/ tree here, it is leakage; clean it up.
.claude/

# Local git worktrees created for repo-scoped agent work.
.worktrees/


# CI output log when using AI=1 flag
.ci-ai.log
